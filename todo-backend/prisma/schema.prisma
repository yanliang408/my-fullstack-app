generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Todo {
  id           BigInt    @id @default(autoincrement())
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  due_date     DateTime? @db.Timestamptz(6)
  title        String?
  is_completed Boolean?
  creatorId    String?   @db.Uuid
  assignedToId String?   @db.Uuid
  creator      User?     @relation("CreatedTodos", fields: [creatorId], references: [id])
  assignee     User?     @relation("AssignedTodos", fields: [assignedToId], references: [id])
}

model User {
  id              String   @id @db.Uuid
  email           String   @unique
  companyId       Int?
  profile         Profile?
  company         Company? @relation("CompanyMembers", fields: [companyId], references: [id])
  ownedCompany    Company? @relation("CompanyOwner")
  createdTodos    Todo[]   @relation("CreatedTodos")
  assignedTodos   Todo[]   @relation("AssignedTodos")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Profile {
  id         Int      @id @default(autoincrement())
  userId     String   @unique @db.Uuid
  fullName   String?
  avatarUrl  String?
  address    String?
  phone      String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Company {
  id         Int      @id @default(autoincrement())
  name       String
  address    String?
  ownerId    String   @unique @db.Uuid
  owner      User     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  users      User[]   @relation("CompanyMembers")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
